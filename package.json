{
  "type": "module",
  "name": "orbit",
  "version": "1.0.0",
  "description": "Orbit is a full-stack productivity platform that visualizes goals as interactive planetary systems, using AI-generated narratives and real-time animations to transform task management into an immersive experience.",
  "main": "src/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "echo \"No tests yet\"",
    "format": "prettier --check \"src/**/*.ts\"",
    "seed:themes": "tsx src/utils/seed-themes.ts"
  },
  "author": "Yousef Mohamed",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "multer": "^2.0.2",
    "pino": "^10.3.1",
    "validator": "^13.15.26",
    "zod": "^4.3.6"
  }
}
